DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_TEXT_MODEL=deepseek-v4-pro

DOUBAO_API_KEY=your_doubao_api_key
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_IMAGE_MODEL=doubao-seedream-4.0
DOUBAO_VIDEO_MODEL=doubao-seedance-1-5-pro-251215

# 可选：如果服务商路径与默认值不同，请覆盖
DOUBAO_IMAGE_ENDPOINT=/images/generations
DOUBAO_VIDEO_ENDPOINT=/contents/generations/tasks
DOUBAO_VIDEO_POLL_PATH=/contents/generations/tasks/{taskId}

# 可选：图生视频参考图 URL（配置后将以图生视频模式调用）
# DOUBAO_VIDEO_REFERENCE_IMAGE_URL=https://example.com/reference.png

# 可选：追加到视频提示词末尾的参数（官方示例格式）
# DOUBAO_VIDEO_TEXT_PARAMS= --duration 5 --camerafixed false --watermark true

# 可选：API 保护（生产环境建议开启）
# CHAT_API_KEY=your_server_api_key
# NEXT_PUBLIC_CHAT_API_KEY=your_server_api_key

# 可选：限流与超时（以下为默认值，可按需覆盖）
# CHAT_RATE_LIMIT_MAX=30
# CHAT_RATE_LIMIT_WINDOW_MS=60000
# UPSTREAM_FETCH_TIMEOUT_MS=120000
# VIDEO_POLL_INTERVAL_MS=3000
# VIDEO_POLL_MAX_ATTEMPTS=40
